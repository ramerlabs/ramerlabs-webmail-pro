# =============================================================================
# RamerLabs Webmail Pro — Environment Variables (optional defaults)
#
# Preferred: configure everything in Admin → Install settings after signing in
# at /admin/login (default admin / admin123 on new installs).
#
# On Vercel, set UPSTASH_REDIS_* here so license + settings persist across deploys.
# Copy to `.env.local` for local overrides if desired.
# =============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
MAIL_DOMAIN=yourdomain.com

# --- Admin mailbox emails (optional; installer admin uses /admin/login) ---
ADMIN_EMAILS=

# --- Session (auto-generated locally if unset; set explicitly on Vercel) ---
# SESSION_SECRET=

# --- Auth profile store ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- System mailer ---
SYSTEM_MAIL_EMAIL=noreply@yourdomain.com
SYSTEM_MAIL_PASSWORD=

# --- cPanel UAPI ---
CPANEL_HOST=mail.yourdomain.com
CPANEL_PORT=2083
CPANEL_USERNAME=
CPANEL_API_TOKEN=
CPANEL_MAILBOX_QUOTA_MB=500

# --- CardDAV / CalDAV URL (optional) ---
DAV_SERVER_URL=https://mail.yourdomain.com:2080

# --- IMAP / SMTP ---
IMAP_HOST=mail.yourdomain.com
IMAP_PORT=993
IMAP_SECURE=true
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=465
SMTP_SECURE=true
MAIL_FROM_NAME=

# --- Bot protection ---
CAPTCHA_PROVIDER=turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
